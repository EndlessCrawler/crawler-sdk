{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/.next/**",
      // Cached map data — large generated JSON, not hand-edited.
      "!packages/crawler-data/src/worlds/**",
      // Archived on-chain token data (tokenURI JSON + SVG + _cache.json) — fetched, not hand-edited.
      "!cache/data/**",
      // Contract artifact JSON + its codegen output (crawler-api) — not hand-edited.
      "!**/artifacts/**",
      "!**/src/generated/**",
      // Tailwind v4 entry CSS — its @import/@theme/@layer directives break Biome's CSS parser.
      "!apps/sdk-explorer/styles/main.css",
      "!**/*.html",
      "!**/*.md",
      "!**/*.svg"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "assist": {
    "actions": {
      "source": {
        // Don't reorder imports on check --write / format-on-save.
        "organizeImports": "off"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      // Rule levels tuned against real lint output in V2 Phase 1 (see specs/V2_PLAN.md).
      // Everything below is tracked migration debt, downgraded to `warn` with a reason — nothing
      // is silently disabled. Each re-tightens in the phase that rewrites the offending code.
      "suspicious": {
        // Re-tightened after the repo-wide `==`→`===` fix; `!= null` stays exempt (catches
        // null + undefined).
        "noDoubleEquals": {
          "level": "error",
          "options": { "ignoreNull": true }
        },
        // noExplicitAny, useIterableCallbackReturn, and noTsIgnore were crawler-api
        // interim-read-path debt — cleared by the P3 contract-layer refactor, so
        // they're back at their recommended (error) levels.
        // Its autofix rewrites our directory content-excludes (`!**/dist/**`) to the bare
        // form, which stops excluding directory *contents* — leave the /** globs intact.
        "useBiomeIgnoreFolder": "off"
      },
      "correctness": {
        // React hook-dep churn in crawler-react hooks, rewritten in a later phase.
        "useExhaustiveDependencies": "off"
        // noSwitchDeclarations, noBlankTarget, and the a11y interaction rules were
        // Phase-7 sdk-explorer debt — cleared by its Tailwind/App-Router rebuild, so
        // they're back at their recommended (error) levels.
      }
    }
  }
}
