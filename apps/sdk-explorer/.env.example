# Crawler SDK Explorer — environment variables
#
# ALL of these are OPTIONAL: the explorer runs with none set (it falls back to a
# public RPC and WalletConnect QR is simply disabled). Copy this file to
# `.env.local` and fill in what you need. `.env.local` is gitignored.

# --- Wallet (client-side, ConnectKit) -----------------------------------------
# WalletConnect project id (free, from https://cloud.reown.com). Needed only for
# WalletConnect QR connections; injected wallets (MetaMask, etc.) work without it.
# Must be NEXT_PUBLIC_ to reach the browser bundle.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- RPC endpoints (provider-agnostic; secure by allowlisting on the dashboard) ---
# Mainnet RPC used by the wallet/wagmi transport in the BROWSER. With none set,
# viem uses the chain's default public RPC.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Mainnet RPC used SERVER-SIDE by the on-chain read routes (/api/read, /api/view)
# via crawler-api. With none set, defaults to https://ethereum-rpc.publicnode.com.
# Not NEXT_PUBLIC_ — it stays on the server.
MAINNET_RPC_URL=
