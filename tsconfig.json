{
  //
  // VSCode-only: maps @avante/* to package sources so "Go To Source Definition" jumps to .ts,
  // not built .d.ts. Each package has its own tsconfig.json (extends tsconfig.base.json) that
  // `tsc --noEmit` type-checks against; tsdown builds. No composite/project references needed.
  //
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@avante/*": ["packages/*/src"]
    }
  },
  "include": ["packages/*/src", "packages/*/test"]
}
