{
  "name": "@avante/crawler-sdk",
  "version": "0.1.0",
  "description": "Endless Crawler SDK Monorepo",
  "author": "Studio Avante",
  "license": "CC0-1.0",
  "homepage": "https://github.com/EndlessCrawler",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "bugs": {
    "url": "https://github.com/EndlessCrawler/crawler-sdk/issues"
  },
  "scripts": {
    "clean": "pnpm --color -r run clean",
    "build": "pnpm --color --filter '@avante/*' --sequential run build",
    "build:core": "pnpm --color --filter '@avante/crawler-core' run build",
    "build:data": "pnpm --color --filter '@avante/crawler-data' run build",
    "build:api": "pnpm --color --filter '@avante/crawler-api' run build",
    "build:react": "pnpm --color --filter '@avante/crawler-react' run build",
    "build:all": "pnpm --color -r run build",
    "watch": "pnpm --filter '@avante/*' --parallel run watch",
    "test": "pnpm --color -r run test",
    "test:core": "pnpm --color --filter '@avante/crawler-core' run test",
    "test:data": "pnpm --color --filter '@avante/crawler-data' run test",
    "test:api": "pnpm --color --filter '@avante/crawler-api' run test",
    "test:react": "pnpm --color --filter '@avante/crawler-react' run test",
    "watch:test": "pnpm --filter '@avante/*' --parallel run watch:test",
    "watch:test:core": "pnpm --filter '@avante/crawler-core' run watch:test",
    "watch:test:data": "pnpm --filter '@avante/crawler-data' run watch:test",
    "watch:test:api": "pnpm --filter '@avante/crawler-api' run watch:test",
    "watch:test:react": "pnpm --filter '@avante/crawler-react' run watch:test",
    "link": "pnpm --color --filter '@avante/*' exec pnpm link --global",
    "unlink": "pnpm --color --filter '@avante/*' exec pnpm unlink",
    "update": "pnpm --color -r run update",
    "typecheck": "pnpm --color --filter '@avante/*' run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:pack": "pnpm --color --filter './packages/*' exec sh -c 'publint --strict && attw --pack . --profile esm-only'"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "2.5.3",
    "publint": "^0.3.21"
  },
  "engines": {
    "node": ">=24.18.0 <25.0.0"
  },
  "keywords": [
    "dungeon",
    "crawler",
    "generative",
    "composable",
    "on-chain",
    "game",
    "web3",
    "erc-721",
    "nft"
  ]
}
