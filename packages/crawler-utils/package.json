{
  "name": "@avante/crawler-utils",
  "version": "0.1.0",
  "description": "Endless Crawler SDK — generic, zero-runtime-dependency utilities (bigint, formatting, encoding, seeding)",
  "author": "Studio Avante",
  "license": "CC0-1.0",
  "homepage": "https://github.com/EndlessCrawler",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bi": {
      "types": "./dist/bi/index.d.ts",
      "import": "./dist/bi/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./encode": {
      "types": "./dist/encode/index.d.ts",
      "import": "./dist/encode/index.js"
    },
    "./seeder": {
      "types": "./dist/seeder/index.d.ts",
      "import": "./dist/seeder/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "watch": "tsdown --watch",
    "watch:test": "vitest"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "js-sha3": "^0.9.3",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "bigint",
    "keccak256",
    "base64",
    "json",
    "utilities",
    "web3"
  ]
}
