		"ts-jest": "catalog:",
		"typescript": "catalog:"
	},
	"keywords": [
		"dungeon",
		"crawler",
		"generative",
		"composable",
		"on-chain",
		"game",
		"web3",
		"erc-721",
		"nft"
	]
