{
  "name": "@avante/crawler-data",
  "version": "0.1.0",
  "description": "Endless Crawler Cached Map Data",
  "author": "Studio Avante",
  "license": "CC0-1.0",
  "homepage": "https://github.com/EndlessCrawler",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "watch": "tsdown --watch",
    "watch:test": "pnpm run test --watch"
  },
  "peerDependencies": {
    "@avante/crawler-core": "workspace:^"
  },
  "devDependencies": {
    "@avante/crawler-core": "workspace:*",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "jest-expect-message": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "dungeon",
    "crawler",
    "generative",
    "composable",
    "on-chain",
    "game",
    "web3",
    "erc-721",
    "nft"
  ]
}
